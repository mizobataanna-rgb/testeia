<style>
:root{
  --ink:#080b12;--ink1:#0c1018;--ink2:#121820;--ink3:#182030;
  --rim:#1a2236;--rim2:#24304a;
  --A:#f0d060;--A2:#c8a832;
  --B:#3ef0c0;--B2:#28b890;
  --R:#f04868;--R2:#a82848;
  --P:#9060ff;
  --W:#ccd8f0;--W1:#7888a8;--W2:#384858;--W3:#1c2838;
  --mono:'IBM Plex Mono',monospace;
  --head:'Bebas Neue',sans-serif;
  --body:'Barlow',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;background:var(--ink);color:var(--W);font-family:var(--body);font-size:14px;overflow-x:hidden}

/* ── BANNER URL (quando não configurado) ── */
#url-banner{
  display:none;
  background:rgba(240,72,104,.1);
  border:1px solid rgba(240,72,104,.35);
  padding:10px 14px;margin:8px;border-radius:3px;
  font-family:var(--mono);font-size:10px;color:var(--R);line-height:1.8;
}
#url-banner b{color:var(--A)}

/* ── TOPBAR ── */
#top{
  height:42px;background:var(--ink1);border-bottom:1px solid var(--rim);
  display:flex;align-items:center;padding:0 12px;gap:0;
  position:sticky;top:0;z-index:100;
}
.logo{font-family:var(--head);font-size:19px;letter-spacing:4px;color:var(--A);
      text-shadow:0 0 18px rgba(240,208,96,.35);margin-right:14px;white-space:nowrap}
.sep{width:1px;height:20px;background:var(--rim);margin:0 10px}
.pill{font-family:var(--mono);font-size:9px;color:var(--W2);display:flex;align-items:center;gap:5px;white-space:nowrap}
.dot{width:6px;height:6px;border-radius:50%}
.dot.ok{background:var(--B);box-shadow:0 0 6px var(--B);animation:blink 1.5s infinite}
.dot.err{background:var(--R);box-shadow:0 0 6px var(--R)}
.dot.wait{background:var(--A);animation:blink 1.5s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.tr{margin-left:auto;display:flex;align-items:center}
.tclk{font-family:var(--mono);font-size:10px;color:var(--A);padding:0 10px;border-left:1px solid var(--rim)}
.tbar{font-family:var(--mono);font-size:8px;color:var(--W2);padding:0 10px;border-left:1px solid var(--rim)}

/* ── TICKER ── */
#tk{height:25px;background:var(--ink2);border-bottom:1px solid var(--rim);overflow:hidden}
#tki{display:flex;align-items:center;height:100%;white-space:nowrap;animation:ts 50s linear infinite}
#tki:hover{animation-play-state:paused}
@keyframes ts{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ti{display:inline-flex;align-items:center;gap:6px;padding:0 14px;height:100%;
    border-right:1px solid var(--rim);font-family:var(--mono);font-size:9px}
.ts{color:var(--A);font-size:8px;font-weight:500}
.tp{color:var(--W)}
.tc.up{color:var(--B)}.tc.dn{color:var(--R)}
.tsg{font-size:7px;padding:1px 4px;border-radius:1px}
.tsg.buy{background:rgba(62,240,192,.12);color:var(--B);border:1px solid rgba(62,240,192,.3)}
.tsg.sell{background:rgba(240,72,104,.12);color:var(--R);border:1px solid rgba(240,72,104,.3)}
.tsg.none{background:rgba(56,72,88,.3);color:var(--W2);border:1px solid var(--rim)}

/* ── ERR STRIP ── */
#errstrip{
  display:none;background:rgba(240,72,104,.1);border-bottom:1px solid rgba(240,72,104,.25);
  font-family:var(--mono);font-size:9px;color:var(--R);text-align:center;padding:4px;
  letter-spacing:.5px;
}

/* ── GRID ── */
#grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;padding:8px}
#bottom{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:0 8px 8px}
#btpanel{margin:0 8px 8px;display:none}
@media(max-width:1280px){#grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:820px){#grid{grid-template-columns:1fr 1fr};#bottom{grid-template-columns:1fr}}
@media(max-width:520px){#grid{grid-template-columns:1fr}}

/* ── CARD ── */
.card{background:var(--ink1);border:1px solid var(--rim);border-radius:3px;overflow:hidden;
      animation:ci .3s ease both}
.card:hover{border-color:var(--rim2)}
@keyframes ci{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.ch{display:flex;align-items:center;gap:6px;padding:7px 10px;background:var(--ink2);border-bottom:1px solid var(--rim)}
.cht{font-family:var(--mono);font-size:8px;color:var(--W2);letter-spacing:1.5px}
.b{font-family:var(--mono);font-size:7px;padding:2px 5px;border-radius:1px;margin-left:auto}
.bg{background:rgba(62,240,192,.1);color:var(--B);border:1px solid rgba(62,240,192,.25)}
.by{background:rgba(240,208,96,.1);color:var(--A);border:1px solid rgba(240,208,96,.25)}
.bp{background:rgba(144,96,255,.1);color:var(--P);border:1px solid rgba(144,96,255,.25)}
.br{background:rgba(240,72,104,.1);color:var(--R);border:1px solid rgba(240,72,104,.25)}

/* ── SIGNAL CARD ── */
.sc{position:relative;overflow:hidden}
.sc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px}
.sc.buy::before{background:var(--B);box-shadow:0 0 8px var(--B)}
.sc.sell::before{background:var(--R);box-shadow:0 0 8px var(--R)}
.sc.no::before{background:var(--W3)}
.sc.buy{box-shadow:0 0 24px rgba(62,240,192,.04) inset}
.sc.sell{box-shadow:0 0 24px rgba(240,72,104,.04) inset}
.sb{padding:10px 10px 10px 13px}
.r1{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px}
.an{font-family:var(--head);font-size:24px;letter-spacing:1px;line-height:1}
.an.gold{color:var(--A)}.an.fx{color:var(--B)}
.st{font-family:var(--head);font-size:13px;letter-spacing:3px;padding:3px 8px;border-radius:1px}
.st.buy{background:rgba(62,240,192,.12);color:var(--B);border:1px solid rgba(62,240,192,.3)}
.st.sell{background:rgba(240,72,104,.12);color:var(--R);border:1px solid rgba(240,72,104,.3)}
.st.no{background:rgba(24,32,48,.7);color:var(--W2);border:1px solid var(--rim)}
.pr{font-family:var(--mono);font-size:15px;color:var(--W);margin:2px 0}
.su{font-family:var(--mono);font-size:8px;color:var(--W2);margin-bottom:6px}
.cv{width:100%;height:58px;display:block;background:var(--ink2);border:1px solid var(--rim);border-radius:2px;margin:5px 0}
.sr{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;margin:6px 0}
.sc2{background:var(--ink2);border:1px solid var(--rim);border-radius:2px;padding:4px 6px}
.sl2{font-family:var(--mono);font-size:7px;color:var(--W2);letter-spacing:1px;margin-bottom:1px}
.sv{font-family:var(--mono);font-size:10px}
.sv.s{color:var(--R)}.sv.t{color:var(--B)}.sv.r{color:var(--A)}
.sb2{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;margin:5px 0}
.sl3{font-family:var(--mono);font-size:7px;color:var(--W2);letter-spacing:1px;margin-bottom:2px}
.st2{height:3px;background:var(--ink3);border-radius:2px;overflow:hidden}
.sf{height:100%;border-radius:2px;transition:width .7s}
.sv2{font-family:var(--mono);font-size:8px;margin-top:2px}
.sv2.p{color:var(--A)}.sv2.c{color:var(--P)}.sv2.f{color:var(--B)}
.fc2{display:flex;flex-wrap:wrap;gap:2px;margin-top:5px}
.fc{font-family:var(--mono);font-size:7px;padding:1px 4px;border-radius:1px}
.fc.ok{background:rgba(62,240,192,.07);color:var(--B2);border:1px solid rgba(62,240,192,.18)}
.fc.fail{background:rgba(240,72,104,.07);color:var(--R2);border:1px solid rgba(240,72,104,.18)}
.str{display:flex;align-items:center;gap:4px;margin-top:4px;font-family:var(--mono);font-size:8px;color:var(--W2)}
.sg{font-size:7px;padding:1px 4px;border-radius:1px;font-weight:600}
.sg.bull{background:rgba(62,240,192,.1);color:var(--B);border:1px solid rgba(62,240,192,.25)}
.sg.bear{background:rgba(240,72,104,.1);color:var(--R);border:1px solid rgba(240,72,104,.25)}
.sg.neu{background:rgba(56,72,88,.2);color:var(--W2);border:1px solid var(--rim)}
.al{display:flex;align-items:center;gap:4px;margin-top:4px;padding:3px 6px;border-radius:2px;font-family:var(--mono);font-size:7px}
.al.sw{background:rgba(240,208,96,.06);border:1px solid rgba(240,208,96,.2);color:var(--A)}
.ts2{font-family:var(--mono);font-size:7px;color:var(--W3);text-align:right;margin-top:4px}

/* ── BT PANEL ── */
.btg{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;padding:9px}
@media(max-width:820px){.btg{grid-template-columns:1fr 1fr}}
.bta{background:var(--ink2);border:1px solid var(--rim);border-radius:2px;padding:9px}
.btn2{font-family:var(--head);font-size:13px;letter-spacing:2px;margin-bottom:5px}
.btn2.gold{color:var(--A)}.btn2.fx{color:var(--B)}
.btt{height:3px;background:var(--ink3);border-radius:2px;margin:4px 0 3px}
.btf{height:100%;border-radius:2px;transition:width 1s}
.btr{display:flex;justify-content:space-between;margin:2px 0;font-family:var(--mono);font-size:8px}
.btl{color:var(--W2)}
.btadj{margin-top:4px;padding:2px 5px;border-radius:1px;font-family:var(--mono);font-size:7px;color:var(--A);background:rgba(240,208,96,.06)}

/* ── SESSIONS ── */
.sw2{padding:9px}
.stl{position:relative;height:32px;background:var(--ink2);border:1px solid var(--rim);border-radius:2px;overflow:hidden;margin-bottom:6px}
.sbl{position:absolute;top:0;bottom:0;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:7px;letter-spacing:1px}
.sbl.lon{background:rgba(62,240,192,.09);color:var(--B)}
.sbl.ny{background:rgba(144,96,255,.09);color:var(--P)}
.sbl.ov{background:rgba(240,208,96,.13);color:var(--A)}
.sbl.as{background:rgba(24,32,48,.4);color:var(--W3)}
.sn{position:absolute;top:0;bottom:0;width:2px;background:var(--A);box-shadow:0 0 6px var(--A);transition:left .5s}
.slb{display:flex;justify-content:space-between;font-family:var(--mono);font-size:7px;color:var(--W3)}

/* ── ZONES ── */
.zl{padding:6px 9px}
.zr{display:flex;align-items:center;gap:5px;padding:4px 0;border-bottom:1px solid var(--rim);font-family:var(--mono);font-size:8px}
.zr:last-child{border:none}
.zt{font-size:6px;padding:1px 3px;border-radius:1px}
.zt.bfvg{background:rgba(62,240,192,.1);color:var(--B);border:1px solid rgba(62,240,192,.25)}
.zt.sfvg{background:rgba(240,72,104,.1);color:var(--R);border:1px solid rgba(240,72,104,.25)}
.zt.bliq{background:rgba(240,208,96,.1);color:var(--A);border:1px solid rgba(240,208,96,.25)}
.zt.sliq{background:rgba(144,96,255,.1);color:var(--P);border:1px solid rgba(144,96,255,.25)}
.za{color:var(--W2);font-size:7px;width:40px}
.zv{color:var(--W);flex:1}
.zd{color:var(--A);font-size:7px}

/* ── STATUS CARD ── */
.stc2{padding:10px;font-family:var(--mono);font-size:8px;color:var(--W2);line-height:1.9}
.stc2 span{color:var(--A)}
.stc2 .ok{color:var(--B)}.stc2 .url{color:var(--W1);word-break:break-all;font-size:7px}

/* ── REFRESH BAR ── */
#rb{position:fixed;bottom:0;left:0;right:0;height:2px;background:var(--rim);z-index:200}
#rf{height:100%;background:linear-gradient(90deg,var(--A2),var(--A));transition:width 1s linear}

/* ── TOOLTIP ── */
#tt{position:fixed;background:var(--ink1);border:1px solid var(--rim2);border-radius:3px;
    padding:8px 10px;font-family:var(--mono);font-size:8px;color:var(--W1);pointer-events:none;
    z-index:500;display:none;max-width:190px;line-height:1.8;box-shadow:0 8px 32px rgba(0,0,0,.8)}
</style>
