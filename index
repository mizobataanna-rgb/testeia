<script>
// ═══════════════════════════════════════════════════════
//  CONSTANTES
// ═══════════════════════════════════════════════════════
const REFRESH = 7000;
const PF = {XAUUSD:2,EURUSD:5,GBPUSD:5,USDJPY:3,AUDUSD:5};

// ── Detecta se URL foi configurada ────────────────────
const URL_OK = typeof API_URL !== 'undefined' &&
               API_URL !== '' &&
               API_URL !== 'COLE_SUA_URL_NGROK_AQUI' &&
               API_URL.startsWith('http');

const BASE = URL_OK ? API_URL.replace(/\/+$/,'') : '';

// ── Mostra banner se não configurada ──────────────────
if(!URL_OK){
  document.getElementById('url-banner').style.display='block';
  document.getElementById('cdot').className='dot err';
  document.getElementById('ctxt').textContent='URL NÃO CONFIGURADA';
  document.getElementById('ctxt').style.color='var(--R)';
}

// ─────────────────────────────────────────────────────
let state = {signals:[],bt:[],bar:0,ts:''};
let rfLeft = REFRESH/1000;
let connOK = false;
let prevPx = {};

// ── CLOCK ─────────────────────────────────────────────
setInterval(()=>{
  document.getElementById('clk').textContent=
    new Date().toISOString().replace('T',' ').split('.')[0]+' UTC';
},1000);

// ── UTILS ─────────────────────────────────────────────
const fmt  = (a,p) => (p||0).toFixed(PF[a]||5);
const fmtN = (n,d=1) => (n||0).toFixed(d);
const sc   = s => s>=75?'var(--B)':s>=60?'var(--A)':s>=45?'var(--R)':'var(--R2)';
const sg   = s => `linear-gradient(90deg,${sc(s)}88,${sc(s)})`;

// ── TICKER ────────────────────────────────────────────
function buildTicker(sigs){
  const items=[...sigs,...sigs];
  document.getElementById('tki').innerHTML=items.map(s=>{
    const prev=prevPx[s.asset]||s.price;
    const up=s.price>=prev; const chg=((s.price-prev)/prev*100).toFixed(3);
    const sg2=s.signal==='BUY'?'buy':s.signal==='SELL'?'sell':'none';
    const st=s.signal==='BUY'?'▲ BUY':s.signal==='SELL'?'▼ SELL':'—';
    return`<div class="ti"><span class="ts">${s.asset}</span><span class="tp">${fmt(s.asset,s.price)}</span><span class="tc ${up?'up':'dn'}">${up?'+':''}${chg}%</span><span class="tsg ${sg2}">${st}</span></div>`;
  }).join('');
}

// ── MINI CHART ────────────────────────────────────────
function drawChart(id,asset,sig){
  const cv=document.getElementById(id); if(!cv)return;
  const ctx=cv.getContext('2d'); const W=cv.width,H=cv.height;
  const N=36,p=sig.price,v=({XAUUSD:.0014,EURUSD:.0003,GBPUSD:.0004,USDJPY:.0003,AUDUSD:.0003})[asset]||.0003;
  const ca=[]; let pp=p*.994;
  for(let i=0;i<N;i++){
    const o=pp,c=o*(1+(Math.random()-.48)*v);
    const h=Math.max(o,c)*(1+Math.random()*v*.3);
    const l=Math.min(o,c)*(1-Math.random()*v*.3);
    ca.push({o,h,l,c});pp=c;
  }
  ca[N-1].c=p;
  const allP=ca.flatMap(c=>[c.h,c.l]);
  const mn=Math.min(...allP),mx=Math.max(...allP),rng=mx-mn||1;
  const ty=p=>H-((p-mn)/rng)*(H-6)-3;
  ctx.clearRect(0,0,W,H);
  const col=sig.signal==='BUY'?'62,240,192':sig.signal==='SELL'?'240,72,104':'56,72,88';
  const gc=ctx.createLinearGradient(0,0,0,H);
  gc.addColorStop(0,`rgba(${col},.13)`);gc.addColorStop(1,'transparent');
  ctx.fillStyle=gc;ctx.fillRect(0,0,W,H);
  const cw=Math.max(2,Math.floor(W/N)-1);
  ca.forEach((c,i)=>{
    const x=i*(W/N)+cw/2,bull=c.c>=c.o,cl=bull?'62,240,192':'240,72,104';
    ctx.strokeStyle=`rgba(${cl},.4)`;ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(x,ty(c.h));ctx.lineTo(x,ty(c.l));ctx.stroke();
    ctx.fillStyle=`rgba(${cl},.7)`;
    const y1=ty(Math.max(c.o,c.c)),y2=ty(Math.min(c.o,c.c));
    ctx.fillRect(x-cw/2,y1,cw,Math.max(1,y2-y1));
  });
  // EMA line
  ctx.strokeStyle='rgba(240,208,96,.55)';ctx.lineWidth=1.1;ctx.beginPath();
  ca.forEach((c,i)=>{
    const sl=ca.slice(Math.max(0,i-8),i+1);
    const avg=sl.reduce((s,c)=>s+c.c,0)/sl.length;
    i===0?ctx.moveTo(i*(W/N)+cw/2,ty(avg)):ctx.lineTo(i*(W/N)+cw/2,ty(avg));
  });ctx.stroke();
  // Price line
  ctx.strokeStyle='rgba(200,216,240,.18)';ctx.lineWidth=1;ctx.setLineDash([2,4]);
  ctx.beginPath();ctx.moveTo(0,ty(p));ctx.lineTo(W,ty(p));ctx.stroke();ctx.setLineDash([]);
  // SL / TP lines
  if(sig.signal==='BUY'||sig.signal==='SELL'){
    [[sig.sl,'240,72,104'],[sig.tp,'62,240,192']].forEach(([lv,c])=>{
      if(!lv)return;const y=ty(Math.max(mn,Math.min(mx,lv)));
      ctx.strokeStyle=`rgba(${c},.4)`;ctx.lineWidth=1;ctx.setLineDash([2,5]);
      ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();ctx.setLineDash([]);
    });
  }
}

// ── SIGNAL CARD ───────────────────────────────────────
function renderCard(s){
  const active=s.signal==='BUY'||s.signal==='SELL';
  const sc2=s.signal==='BUY'?'buy':s.signal==='SELL'?'sell':'no';
  const ac=s.asset==='XAUUSD'?'gold':'fx';
  const str=(s.structure||'NEUTRAL').toLowerCase();
  const cid='cv-'+s.asset;

  const sltp=active?`
  <div class="sr">
    <div class="sc2"><div class="sl2">STOP LOSS</div><div class="sv s">${fmt(s.asset,s.sl)}</div></div>
    <div class="sc2"><div class="sl2">TAKE PROFIT</div><div class="sv t">${fmt(s.asset,s.tp)}</div></div>
    <div class="sc2"><div class="sl2">R:R</div><div class="sv r">1:${s.rr||'—'}</div></div>
  </div>
  <div class="sb2">
    <div><div class="sl3">PROB</div><div class="st2"><div class="sf" style="width:${s.prob||0}%;background:${sg(s.prob||0)}"></div></div><div class="sv2 p">${fmtN(s.prob)}%</div></div>
    <div><div class="sl3">CONF</div><div class="st2"><div class="sf" style="width:${s.confluence||0}%;background:${sg(s.confluence||0)}"></div></div><div class="sv2 c">${fmtN(s.confluence)}%</div></div>
    <div><div class="sl3">SCORE</div><div class="st2"><div class="sf" style="width:${s.final_score||0}%;background:${sg(s.final_score||0)}"></div></div><div class="sv2 f">${fmtN(s.final_score)}%</div></div>
  </div>
  <div class="fc2">${s.filters?Object.entries(s.filters).map(([k,v])=>`<span class="fc ${v?'ok':'fail'}">${k.replace(/_/g,' ')}</span>`).join(''):''}</div>`:'';

  const sw=s.manipulation&&s.manipulation.detected?`<div class="al sw">⚡ ${s.manipulation.dir||''}</div>`:'';

  return`<div class="card sc ${sc2}" id="card-${s.asset}" onmouseenter="showTT(event,'${s.asset}')" onmouseleave="hideTT()">
  <div class="ch"><span class="cht">${s.asset}</span>${active?`<span class="b bp" style="margin-right:3px">ML ${fmtN(s.ml||0)}%</span>`:''}<span class="b ${active?(s.signal==='BUY'?'bg':'br'):'by'}" style="margin-left:${active?'0':'auto'}">${s.signal}</span></div>
  <div class="sb">
    <div class="r1">
      <div><div class="an ${ac}">${s.asset}</div><div class="pr">${fmt(s.asset,s.price)}</div><div class="su">ATR ${fmt(s.asset,s.atr||0)} · RSI ${fmtN(s.rsi)}</div></div>
      <div class="st ${sc2}">${s.signal}</div>
    </div>
    <canvas id="${cid}" class="cv" width="250" height="58"></canvas>
    ${sltp}
    <div class="str">STRUCT:<span class="sg ${str==='bullish'?'bull':str==='bearish'?'bear':'neu'}">${s.structure||'NEUTRAL'}</span>&nbsp;EMA:<span style="color:var(--W1);margin-left:2px">${(s.ema20||0)>(s.ema50||0)?'▲20>50':'▼20<50'}</span></div>
    ${sw}
    <div class="ts2">${new Date(s.timestamp||Date.now()).toISOString().split('T')[1].split('.')[0]} UTC</div>
  </div>
</div>`;
}

// ── BACKTEST PANEL ────────────────────────────────────
function renderBT(bt){
  if(!bt||!bt.length){document.getElementById('btpanel').style.display='none';return;}
  const cards=bt.map(r=>{
    const wr=r.wr||0,wc=wr>=65?'var(--B)':wr>=55?'var(--A)':'var(--R)';
    const adj=r.adj&&r.adj.reason?`<div class="btadj">⚙ ${r.adj.reason}</div>`:'';
    return`<div class="bta">
      <div class="btn2 ${r.asset==='XAUUSD'?'gold':'fx'}">${r.asset}</div>
      <div class="btt"><div class="btf" style="width:${wr}%;background:${wc}"></div></div>
      <div class="btr"><span class="btl">WIN RATE</span><span style="color:${wc}">${wr}%</span></div>
      <div class="btr"><span class="btl">TRADES</span><span style="color:var(--W1)">${r.total||0}</span></div>
      <div class="btr"><span class="btl">AVG R:R</span><span style="color:var(--A)">1:${r.rr||0}</span></div>
      <div class="btr"><span class="btl">PROF.FACTOR</span><span style="color:${(r.pf||0)>=1.5?'var(--B)':'var(--R)'}">${r.pf||0}</span></div>
      ${adj}
    </div>`;
  }).join('');
  const p=document.getElementById('btpanel');
  p.style.display='block';
  p.innerHTML=`<div class="card"><div class="ch"><span class="cht">ROLLING BACKTEST · AUTO-ADJUST ENGINE</span><span class="b by" style="margin-left:auto">WINDOW 500</span></div><div class="btg">${cards}</div></div>`;
}

// ── SESSIONS ──────────────────────────────────────────
function renderSessions(){
  const now=new Date();const h=now.getUTCHours()+now.getUTCMinutes()/60;
  const pct=(h/24)*100;
  const sess=[{n:'ASIAN',s:0,e:8,c:'as'},{n:'LONDON',s:8,e:13,c:'lon'},{n:'OVERLAP',s:13,e:17,c:'ov'},{n:'NY',s:17,e:22,c:'ny'},{n:'',s:22,e:24,c:'as'}];
  const blks=sess.map(s=>`<div class="sbl ${s.c}" style="left:${s.s/24*100}%;width:${(s.e-s.s)/24*100}%">${s.n}</div>`).join('');
  const act=sess.find(s=>h>=s.s&&h<s.e);
  const ac={'lon':'var(--B)','ov':'var(--A)','ny':'var(--P)','as':'var(--W2)'}[act?.c||'as'];
  return`<div class="card"><div class="ch"><span class="cht">SESSIONS</span><span class="b" style="margin-left:auto;color:${ac};border:1px solid ${ac}44;background:rgba(0,0,0,.1)">${act?.n||'OFF'} ATIVA</span></div>
  <div class="sw2"><div class="stl">${blks}<div class="sn" style="left:${pct}%"></div></div>
  <div class="slb"><span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>24:00</span></div></div></div>`;
}

// ── ZONES ─────────────────────────────────────────────
function renderZones(sigs){
  const zones=[];
  sigs.forEach(s=>{
    (s.fvg_zones||[]).forEach(z=>zones.push({...z,asset:s.asset}));
    (s.liquidity_zones||[]).forEach(z=>zones.push({...z,asset:s.asset}));
  });
  const items=zones.slice(0,7).map(z=>{
    const t=z.type||'';
    const cls=t.includes('BULLISH_FVG')?'bfvg':t.includes('BEARISH_FVG')?'sfvg':t.includes('BUY')?'bliq':'sliq';
    const lv=z.mid||z.midpoint||z.level||0;
    const dist=z.dist!=null?(z.dist*100).toFixed(3)+'%':'';
    return`<div class="zr"><span class="zt ${cls}">${t.replace(/_/g,' ').substring(0,10)}</span><span class="za">${z.asset}</span><span class="zv">${fmt(z.asset||'EURUSD',lv)}</span><span class="zd">${dist}</span></div>`;
  }).join('')||'<div style="padding:5px 0;font-family:var(--mono);font-size:8px;color:var(--W3)">Sem zonas ativas</div>';
  return`<div class="card"><div class="ch"><span class="cht">FVG · ZONAS LIQUIDEZ</span><span class="b bp" style="margin-left:auto">INST</span></div><div class="zl">${items}</div></div>`;
}

// ── STATUS CARD ───────────────────────────────────────
function renderStatus(active){
  const urlDisplay=BASE?BASE.replace('https://','').replace('http://','').substring(0,38):'não configurada';
  const ts=state.ts.split('T')[1]?.split('.')[0]||'—';
  return`<div class="card"><div class="ch"><span class="cht">STATUS · mizobataanna.wixsite.com</span></div>
  <div class="stc2">
    <div>Timeframe: <span>M5</span> · Ciclo: <span>15s</span></div>
    <div>Backtest: <span>cada 100 bars</span> · Auto-Adj: <span class="ok">ON</span></div>
    <div>Sinais ativos: <span class="${active>0?'ok':''}">${active}</span> de 5 ativos</div>
    <div style="margin-top:4px;padding-top:4px;border-top:1px solid var(--rim)">
      API: <span class="url">${urlDisplay}</span>
    </div>
    <div>Atualização: <span>${ts} UTC</span></div>
    <div style="margin-top:4px;padding:3px 5px;background:rgba(${connOK?'62,240,192':'240,72,104'},.06);border:1px solid rgba(${connOK?'62,240,192':'240,72,104'},.2);border-radius:2px;font-size:7px;color:var(--${connOK?'B':'R'})">
      ${connOK?'● CONECTADO AO ROBOT':'○ AGUARDANDO CONEXÃO'}
    </div>
  </div></div>`;
}

// ── TOOLTIP ───────────────────────────────────────────
function showTT(e,asset){
  const s=state.signals.find(x=>x.asset===asset); if(!s)return;
  const tt=document.getElementById('tt');
  const active=s.signal==='BUY'||s.signal==='SELL';
  tt.innerHTML=`<span style="color:var(--A)">${asset}</span> <span style="color:${s.signal==='BUY'?'var(--B)':s.signal==='SELL'?'var(--R)':'var(--W2)'}">${s.signal}</span><br>
Preço: ${fmt(asset,s.price)}<br>
${active?`SL: <span style="color:var(--R)">${fmt(asset,s.sl)}</span>  TP: <span style="color:var(--B)">${fmt(asset,s.tp)}</span><br>R:R: 1:${s.rr}<br>Prob: ${fmtN(s.prob)}%  Conf: ${fmtN(s.confluence)}%<br>Score: ${fmtN(s.final_score)}%  ML: ${fmtN(s.ml)}%<br>`:''}Struct: ${s.structure}  RSI: ${fmtN(s.rsi)}<br>${s.manipulation&&s.manipulation.detected?`<span style="color:var(--A)">⚡ ${s.manipulation.dir}</span>`:''}`;
  tt.style.display='block'; tt.style.left=(e.clientX+12)+'px'; tt.style.top=(e.clientY-8)+'px';
}
function hideTT(){ document.getElementById('tt').style.display='none'; }

// ── RENDER ────────────────────────────────────────────
function render(data){
  state.signals=data.signals||[]; state.bt=data.backtest||[];
  state.bar=data.bar||state.bar; state.ts=data.timestamp||'';
  document.getElementById('barn').textContent='BAR #'+state.bar;
  const active=state.signals.filter(s=>s.signal==='BUY'||s.signal==='SELL');
  document.getElementById('btpill').textContent=
    state.bt.length?'BT: '+state.bt.map(r=>r.asset[0]+':'+r.wr+'%').join(' '):'BT: IDLE';

  buildTicker(state.signals);
  document.getElementById('grid').innerHTML=state.signals.map(renderCard).join('');
  document.getElementById('bottom').innerHTML=
    renderSessions()+renderZones(state.signals)+renderStatus(active.length);
  renderBT(state.bt);
  setTimeout(()=>state.signals.forEach(s=>drawChart('cv-'+s.asset,s.asset,s)),40);
  state.signals.forEach(s=>{ prevPx[s.asset]=s.price; });
}

// ── FETCH ─────────────────────────────────────────────
async function fetchData(){
  if(!URL_OK) return;  // não tenta conectar sem URL configurada
  try{
    const r=await fetch(BASE+'/api/signals?t='+Date.now(),
                        {signal:AbortSignal.timeout(5000)});
    if(!r.ok) throw new Error('HTTP '+r.status);
    const data=await r.json();
    render(data);
    document.getElementById('cdot').className='dot ok';
    document.getElementById('ctxt').textContent='CONECTADO · '+BASE.replace('https://','').replace('http://','').substring(0,24);
    document.getElementById('ctxt').style.color='';
    document.getElementById('errstrip').style.display='none';
    document.getElementById('url-banner').style.display='none';
    connOK=true;
  } catch(e){
    document.getElementById('cdot').className='dot err';
    document.getElementById('ctxt').textContent='DESCONECTADO';
    document.getElementById('ctxt').style.color='var(--R)';
    document.getElementById('errstrip').style.display='block';
    connOK=false;
  }
}

// ── REFRESH COUNTDOWN ─────────────────────────────────
setInterval(()=>{
  rfLeft--;
  document.getElementById('rf').style.width=((1-rfLeft/(REFRESH/1000))*100)+'%';
  if(rfLeft<=0){ rfLeft=REFRESH/1000; if(URL_OK) fetchData(); }
},1000);

// ── INIT ──────────────────────────────────────────────
if(URL_OK){
  fetchData();
} else {
  // Mostra estado vazio com banner de instrução
  document.getElementById('cdot').className='dot err';
  document.getElementById('ctxt').textContent='AGUARDANDO URL';
}
</script>
</body>
</html>
